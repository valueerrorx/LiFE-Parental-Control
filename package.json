{
    "name": "life-kiosk",
    "version": "1.0.0",
    "description": "LiFE Parental Control - KDE Plasma parental control tool",
    "productName": "LiFE Parental Control",
    "author": "Thomas Michael Weissel",
    "license": "GPL-3.0",
    "private": true,
    "main": "out/main/index.js",
    "scripts": {
        "dev": "electron-vite dev",
        "compile": "electron-vite build",
        "check": "npm run lint && npm run compile",
        "build": "electron-vite build && electron-builder",
        "lint": "eslint src/main src/preload src/renderer src/shared",
        "dev:root": "sudo -E env XDG_RUNTIME_DIR=/run/user/$(id -u) npx electron-vite dev -- --no-sandbox"
    },
    "dependencies": {
        "bootstrap": "^5.3.3",
        "bootstrap-icons": "^1.11.3",
        "pinia": "^3.0.4",
        "vue": "^3.5.30",
        "vue-router": "^5.0.4"
    },
    "devDependencies": {
        "@vitejs/plugin-vue": "^6.0.5",
        "electron": "^41.0.3",
        "electron-builder": "^26.8.1",
        "electron-vite": "^3.1.0",
        "eslint": "^9.31.0",
        "eslint-plugin-vue": "^10.8.0",
        "sass-embedded": "^1.98.0",
        "vite": "^6.3.5"
    },
    "engines": {
        "node": ">= 22.0.0",
        "npm": ">= 10.0.0"
    }
}
