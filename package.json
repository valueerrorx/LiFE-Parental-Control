{
    "name": "life-parental-control",
    "version": "1.0.2",
    "description": "LiFE Parental Control - KDE Plasma parental control tool",
    "productName": "LiFE Parental Control",
    "author": "Thomas Michael Weissel",
    "license": "GPL-3.0",
    "private": true,
    "main": "out/main/index.js",
    "scripts": {
        "dev": "sudo -E env -u DBUS_SESSION_BUS_ADDRESS XDG_RUNTIME_DIR=/run/user/$(id -u) npx electron-vite dev -- --no-sandbox",
        "compile": "electron-vite build",
        "check": "npm run lint && npm run compile",
        "build": "electron-vite build && electron-builder --publish never",
        "lint": "eslint src/main src/preload src/renderer src/shared",
        "verify:kiosk": "node scripts/verify-kiosk-catalog.mjs"
    },
    "dependencies": {
        "bootstrap": "^5.3.8",
        "bootstrap-icons": "^1.13.1",
        "pinia": "^3.0.4",
        "vue": "^3.5.30",
        "vue-router": "^5.0.4"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@vitejs/plugin-vue": "^6.0.5",
        "electron": "^41.0.3",
        "electron-builder": "^26.8.1",
        "electron-vite": "^5.0.0",
        "eslint": "^10.1.0",
        "eslint-plugin-vue": "^10.8.0",
        "sass-embedded": "^1.98.0",
        "vite": "^7.3.1"
    },
    "engines": {
        "node": ">=24.0.0",
        "npm": ">=10.0.0"
    }
}
